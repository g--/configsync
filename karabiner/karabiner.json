            "complex_modifications": {
                "rules": [
                    {
                        "description": "decrease sonos volume",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f20",
                                    "modifiers": {
                                        "mandatory": ["left_command", "left_option", "left_control"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "shell_command": "$HOME/.pyenv/shims/sonos Study relative_volume -5" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "increase sonos volume",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f21",
                                    "modifiers": {
                                        "mandatory": ["left_command", "left_option", "left_control"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "shell_command": "$HOME/.pyenv/shims/sonos Study relative_volume +5" }],
                                "type": "basic"
                            }
                        ]
